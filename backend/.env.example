# Database
DATABASE_URL=postgresql+asyncpg://brickbanq:brickbanq@localhost:5432/brickbanq
DATABASE_URL_SYNC=postgresql+psycopg2://brickbanq:brickbanq@localhost:5432/brickbanq

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET_KEY=your-super-secret-jwt-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# AWS
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
S3_BUCKET_NAME=brickbanq-documents
SQS_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/123456789/brickbanq-events

# Application
APP_NAME=BrickBanq
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO

# Rate Limiting
RATE_LIMIT_DEFAULT=100/minute
RATE_LIMIT_LOGIN=5/minute
RATE_LIMIT_REGISTER=10/minute
